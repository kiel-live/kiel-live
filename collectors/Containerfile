FROM golang:1.26.1-alpine AS build

ARG COLLECTOR_NAME
ARG VERSION=dev
WORKDIR /src/
COPY . /src/
RUN cd /src/collectors/$COLLECTOR_NAME && CGO_ENABLED=0 go build -ldflags "-X github.com/kiel-live/kiel-live/pkg/version.Version=${VERSION}" -o /bin/collector
RUN mkdir /tmp-for-scratch

FROM scratch
COPY --from=build /tmp-for-scratch /tmp
COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=build /bin/collector /bin/collector
COPY --from=build /usr/local/go/lib/time/zoneinfo.zip /
ENV ZONEINFO=/zoneinfo.zip

ENTRYPOINT ["/bin/collector"]
