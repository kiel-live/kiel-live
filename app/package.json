{
  "name": "@kiel-live/app",
  "author": "Kiel-Live Team",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.5.2"
  },
  "scripts": {
    "dev": "VITE_BUILD_DATE=$(date '+%d.%m.%Y %H:%M:%S') vite",
    "build": "VITE_BUILD_DATE=$(date '+%d.%m.%Y %H:%M:%S') vite build",
    "build:test": "VITE_BUILD_DATE='01.01.1970 00:00:00' vite build",
    "preview": "vite preview",
    "lint": "eslint --max-warnings 0 .",
    "formatcheck": "prettier -c .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "docker run --rm -it -v $(pwd):/app --network=host mcr.microsoft.com/playwright:v1.58.2 bash -c \"npm i -g corepack && cd /app && pnpm run test:e2e -u\" && sudo chown -R $USER:$USER tests test-results dist",
    "translate": "pnpx @geprog/translator translate ./src/locales"
  },
  "dependencies": {
    "@nats-io/jetstream": "3.3.1",
    "@nats-io/nats-core": "3.3.1",
    "@vueuse/core": "14.3.0",
    "canvas-confetti": "1.9.4",
    "fuse.js": "7.3.0",
    "maplibre-gl": "5.24.0",
    "micromark": "4.0.2",
    "vue": "3.5.33",
    "vue-i18n": "11.4.0",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.3.0",
    "@eslint/js": "10.0.1",
    "@iconify-json/carbon": "1.2.23",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/ph": "1.2.2",
    "@intlify/eslint-plugin-vue-i18n": "4.3.0",
    "@intlify/unplugin-vue-i18n": "11.1.2",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/canvas-confetti": "1.9.0",
    "@types/geojson": "7946.0.16",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "6.0.6",
    "eslint": "10.5.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-vue-scoped-css": "3.1.1",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "32.1.0",
    "vite": "7.3.5",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1",
    "yaml-eslint-parser": "1.3.2"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
